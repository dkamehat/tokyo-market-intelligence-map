# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# `.env` is gitignored. The application ID must never appear in a commit or a log.

# Free e-Stat application ID. Register at https://www.e-stat.go.jp/api/
ESTAT_APP_ID=your-estat-application-id

# statsDataId of the e-Stat table to ingest.
# Pin this from the e-Stat table search (see docs/data_sources.md for the
# recommended Population Census table). Leave unset to run ingestion in sample mode.
ESTAT_STATS_DATA_ID=your-stats-data-id
